#!/usr/bin/env bash
# pi-delegate: Launch pi with the correct environment for a delegated session.
#
# Re-execs under a login shell with per-directory environment (shadowenv)
# activated — both concerns handled in a single pass.

if command -v shadowenv &>/dev/null; then
  exec "$SHELL" -lc "$(printf '%q ' shadowenv exec -- pi "$@")"
fi

exec "$SHELL" -lc "$(printf '%q ' pi "$@")"
