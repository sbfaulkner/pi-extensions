#!/usr/bin/env bash
# pi-delegate: Launch pi with the correct environment for a delegated session.
#
# 1. Re-exec under a login shell so .zshrc/.bashrc are sourced (PATH, nix, etc.)
# 2. Activate per-directory environment (shadowenv) which otherwise won't fire
#    without a prompt being drawn.

# Guard against infinite recursion: if we're already in the login shell, skip.
if [[ "$__PI_WITH_ENV" != 1 ]]; then
  export __PI_WITH_ENV=1
  exec "$SHELL" -lc "$(printf '%q ' "$0" "$@")"
fi

if command -v shadowenv &>/dev/null; then
  exec shadowenv exec -- pi "$@"
fi

exec pi "$@"
